{
    "tabWidth": 4,
    "useTabs": false,
    "printWidth": 125,
    "trailingComma": "none",
    "arrowParens": "avoid",
    "bracketSpacing": true,
    "singleQuote": false,
    "semi": true,
    "endOfLine": "lf",

    "plugins": ["@ianvs/prettier-plugin-sort-imports"],

    "importOrder": [
        "<TYPES>",
        "<TYPES>^@vimcord/(.*)$",
        "<TYPES>^@/(.*)$",
        "<TYPES>^[./]",
        "",
        "<BUILTIN_MODULES>",
        "<THIRD_PARTY_MODULES>",
        "^@vimcord/(.*)$",
        "^@/(.*)$",
        "^[./]"
    ]
}
